# Hub compose stack — copy to .env and fill in required values
# Required fields are marked with *

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=verifiably
POSTGRES_USER=verifiably
POSTGRES_PASSWORD=change-me-in-production  # *

# ── Hub application ──────────────────────────────────────────────────────────
# Public-facing URL of this Hub (used in trust registry JWTs and QR codes)
VERIFIABLY_PUBLIC_URL=https://verify.cdpi.dev  # *

# Session encryption key — generate: openssl rand -hex 32
VERIFIABLY_SESSION_SECRET=change-me-in-production  # *

# ECDSA P-256 private key for ES256 trust registry JWT signing.
# Generate:
#   openssl ecparam -name prime256v1 -genkey -noout -out key.pem
#   openssl pkcs8 -topk8 -nocrypt -in key.pem -out trust-signing-key.pem
#   cat trust-signing-key.pem  → paste value here (with literal \n or multiline)
# If unset, an ephemeral key is used (public key changes on restart — not suitable for production).
VERIFIABLY_TRUST_SIGNING_KEY=

# Admin panel password (leave blank to use default OIDC-only flow)
VERIFIABLY_ADMIN_PASSWORD=

# API keys for /metrics endpoint protection (name:key pairs, comma-separated)
# Example: prometheus:secret-key-123
VERIFIABLY_API_KEYS=

# ── Monitoring ────────────────────────────────────────────────────────────────
HUB_PORT=8080
PROMETHEUS_PORT=9090
GRAFANA_PORT=3100
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-in-production  # *

# External Grafana URL shown as a link in the admin metrics UI
GRAFANA_EXTERNAL_URL=http://localhost:3100

# ── Docker image ──────────────────────────────────────────────────────────────
# Override to use a specific tag: verifiably/verifiably-go:v1.2.3
VERIFIABLY_IMAGE=verifiably/verifiably-go:latest
