# Hub compose stack - copy to .env and fill in required values
# Required fields are marked with *

# --- Database ---
POSTGRES_DB=verifiably
POSTGRES_USER=verifiably
POSTGRES_PASSWORD=change-me-in-production  # *

# --- Hub application ---
# Public-facing URL of this Hub (used in trust registry JWTs and QR codes)
VERIFIABLY_PUBLIC_URL=https://verify.cdpi.dev  # *

# Session encryption key - generate: openssl rand -hex 32
VERIFIABLY_SESSION_SECRET=change-me-in-production  # *

# ECDSA P-256 private key for ES256 trust registry JWT signing.
# Generate:
#   openssl ecparam -name prime256v1 -genkey -noout -out key.pem
#   openssl pkcs8 -topk8 -nocrypt -in key.pem -out trust-signing-key.pem
# Loaded automatically from config/trust-signing-key.pem (mounted in container).
# Set here only to override the file mount (e.g. in CI/CD without a bind mount).
VERIFIABLY_TRUST_SIGNING_KEY=

# Admin panel password - generate: openssl rand -base64 18
# Required in production. Blank = OIDC-only login (no local admin account).
VERIFIABLY_ADMIN_PASSWORD=change-me-in-production  # *

# API keys for /metrics endpoint protection (name:key pairs, comma-separated)
# Example: prometheus:secret-key-123
VERIFIABLY_API_KEYS=

# --- TLS / Production subdomain mode ---
# Set both to activate the Caddy reverse proxy (tls compose profile) with
# automatic Let's Encrypt certificates. Leave both empty for localhost / dev
# (direct port-bind mode). DNS must resolve VERIFIABLY_PUBLIC_DOMAIN to this
# host before running deploy.sh up hub with these set.
#
# Example:
#   VERIFIABLY_PUBLIC_DOMAIN=verify.cdpi.dev
#   -> Hub:     https://verify.cdpi.dev
#   -> Grafana: https://grafana.verify.cdpi.dev
VERIFIABLY_PUBLIC_DOMAIN=
VERIFIABLY_LE_EMAIL=

# --- Monitoring ---
HUB_PORT=8080
# Prometheus is bound to loopback (127.0.0.1) by default so it is not
# reachable from the public internet. Override to 0.0.0.0:9090 only for
# internal network access (e.g. a bastion host that scrapes this instance).
PROMETHEUS_PORT=127.0.0.1:9090
GRAFANA_PORT=3100
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-in-production  # *

# External Grafana URL shown as a link in the admin metrics UI.
# In localhost mode: http://localhost:3100
# In TLS mode: https://grafana.<VERIFIABLY_PUBLIC_DOMAIN>  (set automatically
# by deploy.sh when VERIFIABLY_PUBLIC_DOMAIN is entered during setup)
GRAFANA_EXTERNAL_URL=http://localhost:3100

# --- Docker image ---
# Override to use a specific tag: verifiably/verifiably-go:v1.2.3
VERIFIABLY_IMAGE=verifiably/verifiably-go:latest
