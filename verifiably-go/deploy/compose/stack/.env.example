# Copy this to `.env` and edit for your environment. Docker Compose
# reads `.env` automatically from the same directory as the compose
# file. The seed scripts under docker/injiweb/ also source this file.
#
# The ONE variable you almost always need to change for a non-laptop
# deployment is PUBLIC_HOST.

# -----------------------------------------------------------------------------
# Browser-visible hostname for ALL public URLs the user follows in a browser
# (Inji Web UI, eSignet oidc-ui, vcplatform Go app). Must ALSO be reachable
# from inside containers on the waltid_default docker network, because
# Mimoto reads esignet's advertised token endpoint URL directly out of
# esignet's well-known and posts to it from inside its container.
#
# Laptop (browser on the same host as Docker):
#     PUBLIC_HOST=172.24.0.1
#   — the waltid_default bridge gateway IP. Published ports are bound on
#     0.0.0.0, so both the browser AND Mimoto's container reach the
#     oidc-ui container via 172.24.0.1:3005.
#
# EC2 / remote host (browser on a different machine than Docker):
#     PUBLIC_HOST=<ec2-public-hostname-or-ip>
#   — the EC2 instance's public address. From the browser it reaches
#     the published ports; from inside Mimoto's container it resolves
#     to the host's external interface and loops back through docker's
#     port forward. If the EC2 is using a private IP, use that.
#
# Docker Desktop / Linux with /etc/hosts entry:
#     PUBLIC_HOST=host.docker.internal
#   — only if you've added `127.0.0.1 host.docker.internal` to your
#     host's /etc/hosts. Docker Desktop does this automatically; native
#     Linux Docker does not.
PUBLIC_HOST=172.24.0.1

# Port the browser uses to reach the eSignet oidc-ui container. The
# container internally listens on :3000 and is mapped to host :3005
# by default. Change here only if :3005 is already in use on your host.
ESIGNET_PUBLIC_PORT=3005

# Port the browser uses to reach the Inji Web UI container. The
# container listens on :3004 and is mapped to host :3004.
INJIWEB_UI_PUBLIC_PORT=3004

# Password and alias for the wallet-demo-client PKCS12 keystore that
# Mimoto uses to sign private_key_jwt assertions to esignet. These
# must match the p12 at docker/injiweb/config/certs/oidckeystore.p12.
# See docker/injiweb/README.md for how to replace the keystore.
INJIWEB_P12_PASSWORD=xy4gh6swa2i

# Google OAuth creds for Mimoto's wallet-backup-to-Drive feature.
# Dummy values are fine for local demos — Mimoto logs a warning and
# continues without the backup feature.
GOOGLE_OAUTH_CLIENT_ID=dummy-client-id
GOOGLE_OAUTH_CLIENT_SECRET=dummy-client-secret


VERIFIABLY_PUBLIC_DOMAIN=verifiably.ysalabs.work
VERIFIABLY_HOSTS_PATTERN=https://%s.verifiably.ysalabs.work
VERIFIABLY_LE_EMAIL=you@example.com