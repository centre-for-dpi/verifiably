# Caddyfile.public — generated by deploy.sh's render_public_caddyfile().
# Do NOT edit this file directly; changes will be overwritten on the next
# ./deploy.sh up. Customise via VERIFIABLY_SLUG_<NAME> env vars in .env
# instead — see docs/deploy.md § Per-subdomain deployment.

{
	email isaiasalvarez@gmail.com
}

(security_headers) {
	header {
		X-Content-Type-Options  nosniff
		X-Frame-Options         DENY
		X-XSS-Protection        "1; mode=block"
		Referrer-Policy         strict-origin-when-cross-origin
		Permissions-Policy      "camera=(), microphone=(), geolocation=(), payment=()"
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		-Server
	}
}

walt-issuer.verifiably.ysalabs.work {
	import security_headers
	handle /.well-known/did.json {
		header Content-Type "application/json"
		header Access-Control-Allow-Origin "*"
		respond `{"@context": ["https://www.w3.org/ns/did/v1", "https://w3id.org/security/suites/jws-2020/v1"], "id": "did:web:walt-issuer.verifiably.ysalabs.work", "verificationMethod": [{"id": "did:web:walt-issuer.verifiably.ysalabs.work#key-1", "type": "JsonWebKey2020", "controller": "did:web:walt-issuer.verifiably.ysalabs.work", "publicKeyJwk": {"kty": "EC", "crv": "P-256", "kid": "QhLpN-Wvio-wRDow3ZMuocNu2VhwnF8Q3T1U_NN12bg", "x": "vUn4XfHXuXrst6bXLeZKMJtQCgoqAWnT3-X1tyy7ax4", "y": "08hb-w2V41VTEQP9yyabHNnXg5hd7JCZGxg8Eva0950"}}], "assertionMethod": ["did:web:walt-issuer.verifiably.ysalabs.work#key-1"], "authentication": ["did:web:walt-issuer.verifiably.ysalabs.work#key-1"]}` 200
	}
	reverse_proxy issuer-api:7002
}

walt-wallet.verifiably.ysalabs.work {
	import security_headers
	reverse_proxy wallet-api:7001
}

walt-verifier.verifiably.ysalabs.work {
	import security_headers
	reverse_proxy verifier-api:7003
}

inji-certify.verifiably.ysalabs.work {
	import security_headers
	reverse_proxy certify-nginx:80
}

inji-certify-preauth.verifiably.ysalabs.work {
	import security_headers
	reverse_proxy certify-preauth-nginx:80
}

inji-verify.verifiably.ysalabs.work {
	import security_headers
	handle /v1/verify/.well-known/did.json {
		header Content-Type "application/did+ld+json"
		header Access-Control-Allow-Origin "*"
		respond `{"@context": ["https://www.w3.org/ns/did/v1", "https://w3id.org/security/suites/ed25519-2020/v1"], "id": "did:web:inji-verify.verifiably.ysalabs.work:v1:verify", "verificationMethod": [{"id": "did:web:inji-verify.verifiably.ysalabs.work:v1:verify#key-0", "type": "Ed25519VerificationKey2020", "controller": "did:web:inji-verify.verifiably.ysalabs.work:v1:verify", "publicKeyMultibase": "z6MkkzruJN9axHYvD6xjym3FrMiPTGaZKuL9LFtt8bQMcEvC"}], "authentication": ["did:web:inji-verify.verifiably.ysalabs.work:v1:verify#key-0"]}` 200
	}
	reverse_proxy inji-verify-service:8080
}

inji-verify-ui.verifiably.ysalabs.work {
	import security_headers
	reverse_proxy inji-verify-ui:8000
}

inji-web.verifiably.ysalabs.work {
	import security_headers
	reverse_proxy injiweb-ui:3004
}

mimoto.verifiably.ysalabs.work {
	import security_headers
	reverse_proxy injiweb-mimoto:8099
}

esignet.verifiably.ysalabs.work {
	import security_headers
	reverse_proxy injiweb-oidc-ui:3000
}

keycloak.verifiably.ysalabs.work {
	import security_headers
	reverse_proxy keycloak:8180
}

wso2.verifiably.ysalabs.work {
	import security_headers
	reverse_proxy https://wso2is:9443 {
		transport http {
			tls_insecure_skip_verify
		}
	}
}

verifiably.ysalabs.work {
	import security_headers
	reverse_proxy verifiably-go:8080
}

credebl.verifiably.ysalabs.work {
	import security_headers
	handle /oid4vci/* {
		reverse_proxy credebl-oid4vci-rewriter:80
	}
	handle /oid4vp/* {
		reverse_proxy credebl-oid4vci-rewriter:80
	}
	handle /openid4vc/* {
		reverse_proxy credebl-oid4vci-rewriter:80
	}
	handle /.well-known/did.json {
		reverse_proxy credebl-oid4vci-rewriter:80
	}
	reverse_proxy credebl-api-gateway:5000
}

credebl-minio.verifiably.ysalabs.work {
	import security_headers
	reverse_proxy credebl-minio:9000
}

grafana.verifiably.ysalabs.work {
	import security_headers
	reverse_proxy grafana:3000
}

