{
  "title": "Verifiably — Ecosystem Overview",
  "uid": "verifiably-ecosystem-v1",
  "description": "Hub-level observability: issuance and verification totals across all federation members, per-issuer breakdown, and Trust Registry health.",
  "tags": ["verifiably", "hub", "ecosystem", "federation"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "links": [
    {
      "title": "Single-instance dashboard",
      "url": "/d/verifiably-metrics-v1",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },

  "templating": {
    "list": [
      {
        "name": "issuer",
        "label": "Issuer",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(up{job=\"verifiably-federation\"}, issuer_name)",
        "query": {
          "query": "label_values(up{job=\"verifiably-federation\"}, issuer_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "current": {},
        "options": [],
        "hide": 0
      },
      {
        "name": "interval",
        "label": "Rate window",
        "type": "interval",
        "query": "1m,5m,15m,30m,1h",
        "current": { "text": "5m", "value": "5m" },
        "hide": 0,
        "auto": false
      }
    ]
  },

  "panels": [

    {
      "id": 100,
      "type": "row",
      "title": "Ecosystem Totals",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 1,
      "type": "stat",
      "title": "Active Issuers",
      "description": "Number of federation member /metrics endpoints currently reachable.",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(up{job=\"verifiably-federation\"} == 1)",
          "instant": true,
          "legendFormat": "active"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "noValue": "0"
        }
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Issued (federation, 24h)",
      "description": "Total credentials issued across all federation members in the selected time range.",
      "gridPos": { "x": 4, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(credential_issued_total{job=\"verifiably-federation\", status=\"ok\", issuer_name=~\"$issuer\"}[$__range])))",
          "instant": true,
          "legendFormat": "issued"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "noValue": "0"
        }
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Verified at Hub (24h)",
      "description": "Completed OID4VP verifications processed by this Hub in the selected range.",
      "gridPos": { "x": 9, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "round(sum(increase(verification_completed_total{job=~\"verifiably-federation|verifiably-hub\"}[$__range])))",
          "instant": true,
          "legendFormat": "verified"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "noValue": "0"
        }
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Hub Verification Valid Rate",
      "description": "Percentage of completed verifications that were cryptographically valid.",
      "gridPos": { "x": 14, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(increase(verification_completed_total{job=~\"verifiably-federation|verifiably-hub\", status=\"ok\"}[$__range])) / sum(increase(verification_completed_total{job=~\"verifiably-federation|verifiably-hub\"}[$__range]))",
          "instant": true,
          "legendFormat": "valid %"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "decimals": 1,
          "noValue": "—",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Unreachable Issuers",
      "description": "Federation members whose /metrics endpoint is currently down.",
      "gridPos": { "x": 19, "y": 1, "w": 5, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(up{job=\"verifiably-federation\"} == 0) OR vector(0)",
          "instant": true,
          "legendFormat": "down"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "noValue": "0"
        }
      }
    },

    {
      "id": 200,
      "type": "row",
      "title": "Verification Trends",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Verification Rate by Issuer",
      "description": "Rate of completed verifications per issuer (credentials issued by each member, verified at the Hub).",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (issuer_name) (rate(verification_completed_total{job=\"verifiably-federation\", issuer_name=~\"$issuer\"}[$interval]))",
          "legendFormat": "{{issuer_name}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          }
        }
      }
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Issuance Rate by Member",
      "description": "Rate of successful credential issuances per federation member (scraped from each issuer's /metrics).",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (issuer_name) (rate(credential_issued_total{job=\"verifiably-federation\", status=\"ok\", issuer_name=~\"$issuer\"}[$interval]))",
          "legendFormat": "{{issuer_name}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          }
        }
      }
    },

    {
      "id": 300,
      "type": "row",
      "title": "Per-Issuer Breakdown",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 20,
      "type": "table",
      "title": "Issuer Activity Table (24h)",
      "description": "Per-issuer totals for the selected time range. Issued = from member /metrics. Verified = credentials of this issuer verified at the Hub.",
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "issued",
          "expr": "round(sum by (issuer_name) (increase(credential_issued_total{job=\"verifiably-federation\", status=\"ok\"}[$__range])))",
          "instant": true,
          "legendFormat": "{{issuer_name}}",
          "format": "table"
        },
        {
          "refId": "verified",
          "expr": "round(sum by (issuer_name) (increase(verification_completed_total{job=\"verifiably-federation\"}[$__range])))",
          "instant": true,
          "legendFormat": "{{issuer_name}}",
          "format": "table"
        },
        {
          "refId": "valid",
          "expr": "round(sum by (issuer_name) (increase(verification_completed_total{job=\"verifiably-federation\", status=\"ok\"}[$__range])))",
          "instant": true,
          "legendFormat": "{{issuer_name}}",
          "format": "table"
        },
        {
          "refId": "up",
          "expr": "up{job=\"verifiably-federation\"}",
          "instant": true,
          "legendFormat": "{{issuer_name}}",
          "format": "table"
        }
      ],
      "options": {
        "sortBy": [{ "displayName": "Verified", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "1": { "text": "✓ up", "color": "green" }, "0": { "text": "✗ down", "color": "red" } } }
                ]
              },
              { "id": "custom.width", "value": 80 }
            ]
          }
        ]
      },
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "issuer_name": "Issuer",
              "Value #issued": "Issued",
              "Value #verified": "Verified",
              "Value #valid": "Valid",
              "Value #up": "Status"
            },
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "issuer_did": true
            }
          }
        }
      ]
    },

    {
      "id": 400,
      "type": "row",
      "title": "Trust Registry Health",
      "description": "Requires Fase 9 (Trust Registry Health Monitoring) to emit gauge metrics.",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 30,
      "type": "bargauge",
      "title": "Days Until Accreditation Expires",
      "description": "Days remaining before each member's trust registry accreditation expires. Requires trusted_issuer_days_until_expiry gauge (Fase 9).",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "trusted_issuer_days_until_expiry",
          "instant": true,
          "legendFormat": "{{name}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "min": 0,
          "color": { "mode": "thresholds" },
          "noValue": "no expiry",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 90 }
            ]
          }
        }
      }
    },

    {
      "id": 31,
      "type": "stat",
      "title": "Issuers Expiring < 30 Days",
      "description": "Count of members whose accreditation expires within 30 days. Alert threshold for Fase 9.",
      "gridPos": { "x": 12, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(trusted_issuer_days_until_expiry < 30) OR vector(0)",
          "instant": true,
          "legendFormat": "expiring soon"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },

    {
      "id": 32,
      "type": "stat",
      "title": "Issuers Endpoint Down",
      "description": "Members whose serviceEndpoint /healthz check is failing. Requires trusted_issuer_endpoint_up gauge (Fase 9).",
      "gridPos": { "x": 18, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(trusted_issuer_endpoint_up == 0) OR vector(0)",
          "instant": true,
          "legendFormat": "endpoint down"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },

    {
      "id": 33,
      "type": "table",
      "title": "Trust Registry Health Table",
      "description": "Per-issuer expiry and endpoint status. Requires Fase 9 gauges: trusted_issuer_days_until_expiry and trusted_issuer_endpoint_up.",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "expiry",
          "expr": "trusted_issuer_days_until_expiry",
          "instant": true,
          "legendFormat": "{{name}}",
          "format": "table"
        },
        {
          "refId": "endpoint",
          "expr": "trusted_issuer_endpoint_up",
          "instant": true,
          "legendFormat": "{{name}}",
          "format": "table"
        }
      ],
      "options": {
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "noValue": "—" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Endpoint" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "1": { "text": "✓ up", "color": "green" }, "0": { "text": "✗ down", "color": "red" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Days" },
            "properties": [
              { "id": "unit", "value": "d" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 30 },
                    { "color": "green", "value": 90 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "name": "Issuer",
              "Value #expiry": "Days",
              "Value #endpoint": "Endpoint"
            },
            "excludeByName": { "Time": true, "did": true, "job": true, "instance": true }
          }
        }
      ]
    }

  ]
}
