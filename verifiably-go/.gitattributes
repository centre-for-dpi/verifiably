# Normalize line endings: text files use LF in the repo.
# On Windows, git's autocrlf would otherwise mark config files as
# modified (LF→CRLF) without any real content change.
* text=auto eol=lf

# Binaries: no conversion.
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.pdf binary
