# Sibling projects — kept local only; not part of the verifiably-go repo.
# Re-add any of these if the split reverses. Leading slashes anchor to
# the repo root so verifiably-go/scripts/ etc. aren't accidentally
# matched (was hiding new bootstrap scripts).
/ui-demo/
/scripts/
/references/
/agent-service/

# Plans
go-build-plan.md

# Loose scratch copy of the wallet-demo-client p12 — the real copy lives
# at verifiably-go/deploy/compose/injiweb/config/certs/oidckeystore.p12
# which IS tracked.
/oidckeystore.p12/


# verifiably-go runtime state
# - config/*.json is rendered from deploy.sh stanzas on every `deploy.sh run`
# - *.docker.json / *.rendered.yml are ephemeral docker-internal overrides
# - wso2is.env is written by scripts/bootstrap-wso2is.sh
# - locales/*.json is the LibreTranslate disk cache
# - walletbag.json persists the demo wallet credentials between runs
# - cookies.txt is a curl/test artifact
verifiably-go/config/backends.json
verifiably-go/config/backends.docker.json
verifiably-go/config/auth-providers.json
verifiably-go/config/auth-providers.docker.json
verifiably-go/config/auth-providers.system.json
verifiably-go/config/auth-providers.system.docker.json
verifiably-go/config/auth-providers.user.json
verifiably-go/config/auth-providers.docker.json.bak
verifiably-go/config/auth-providers.docker.json.bak.migrated
verifiably-go/config/custom-schemas.user.json
# Rendered from wso2-deployment.toml.template by deploy.sh; contains the
# current VERIFIABLY_PUBLIC_HOST which differs per deployment.
verifiably-go/deploy/compose/stack/wso2-deployment.toml
verifiably-go/config/docker-compose.injiweb-fix.rendered.yml
verifiably-go/config/wso2is.env
verifiably-go/locales/
verifiably-go/walletbag.json
verifiably-go/cookies.txt
verifiably-go/node_modules/
verifiably-go/.env
# Guard: never commit node_modules anywhere (directory or symlink)
node_modules
node_modules/

# Compiled inji-preauth-proxy binary — rebuilt from main.go via go build
verifiably-go/cmd/inji-preauth-proxy/inji-preauth-proxy

# Python bytecode cache from testdata/bulk-issuance helpers
__pycache__/
*.pyc

# Compiled verifiably-go binary from a top-level `go build ./cmd/server` —
# the canonical output lives under cmd/inji-preauth-proxy/ when the user
# wants a checked-in artifact; this one is just a local convenience.
verifiably-go/server

# Terraform state and provider caches under deploy/k8s/. Provider binaries
# are >150 MiB each and are reproduced by `terraform init`; tfstate may
# contain cluster credentials and kubeconfigs that must never reach git.
# .terraform.lock.hcl IS committed — that pins versions for reproducible
# `init` runs.
verifiably-go/deploy/k8s/**/.terraform/
verifiably-go/deploy/k8s/**/*.tfstate
verifiably-go/deploy/k8s/**/*.tfstate.backup
verifiably-go/deploy/k8s/**/*.tfplan
# Script-local terraform output dirs (kubeconfig, rendered kind config).
verifiably-go/deploy/k8s/terraform/.tfstate/
verifiably-go/deploy/k8s/terraform/bootstrap/local-kind/.tfstate/

# Walt.id issuer credential catalog (runtime). The committed
# *.baseline.conf is the seed; deploy.sh cp -n's it to the runtime path
# below on first `up`. User-added schemas (from the issuer's UI) get
# appended to the runtime file by internal/adapters/waltid/issuer.go,
# and we DO NOT want git to revert that on the next pull/checkout.
verifiably-go/deploy/k8s/config/issuer/credential-issuer-metadata.conf
verifiably-go/deploy/compose/hub/.env
verifiably-go/deploy/compose/credebl/config/credebl.env
verifiably-go/deploy/compose/credebl/.agent-runtime/endpoints/dfffc22c-e706-49ad-87f7-8568e8d856e0_Platform-admin.json
verifiably-go/deploy/compose/credebl/.agent-runtime/agent-config/dfffc22c-e706-49ad-87f7-8568e8d856e0_Platform-admin.json
verifiably-go/deploy/compose/credebl/.agent-runtime/nginx-oid4vci.conf
verifiably-go/deploy/compose/credebl/.agent-runtime/agent.env
verifiably-go/config/trust-signing-key.pem
